---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SkillHeader from "../../../components/SkillHeader";
import { GitHubIcon } from "../../../components/Icons";
import { loadAllSkills } from "../../../data/skills";
import { SITE_URL, BASE_PATH } from "../../../data/site";
import { marked } from "marked";
import "../../../styles/global.css";

marked.setOptions({ gfm: true, breaks: false });

export function getStaticPaths() {
  const skills = loadAllSkills();
  return skills.map((skill) => ({
    params: { slug: skill.id },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const html = marked.parse(skill.content);
const site = SITE_URL;
const url = `${site}/skills/${skill.id}/`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: `${skill.name} — IC Skills`,
  description: skill.description,
  url,
  version: skill.version,
  author: { "@type": "Organization", name: "DFINITY Foundation", url: "https://dfinity.org" },
  about: { "@type": "Thing", name: skill.name },
  isPartOf: { "@id": `${site}/#website` },
  proficiencyLevel: "Expert",
  keywords: `Internet Computer, ICP, ${skill.name}, ${skill.category}, AI agent, icp-cli`,
});
---

<BaseLayout
  title={`${skill.name} — IC Skills`}
  description={skill.description}
  canonicalUrl={url}
  ogTitle={`${skill.name} — IC Skills`}
  ogDescription={skill.description}
  jsonLd={jsonLd}
>
  <div style="min-height:100vh;background:var(--bg-page);color:var(--text-body);font-family:'JetBrains Mono','SF Mono','Fira Code',monospace;position:relative;overflow:hidden;">
    <!-- Grid background -->
    <div style="position:fixed;inset:0;opacity:var(--grid-opacity);background-image:linear-gradient(rgba(var(--accent-rgb),0.5) 1px,transparent 1px),linear-gradient(90deg,rgba(var(--accent-rgb),0.5) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;"></div>

    <!-- Glow orbs -->
    <div style="position:fixed;top:-200px;right:-200px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,var(--glow-1) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="position:fixed;bottom:-300px;left:-100px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,var(--glow-2) 0%,transparent 70%);pointer-events:none;"></div>

    <!-- Interactive header (Preact island) -->
    <SkillHeader
      client:load
      skillId={skill.id}
      skillName={skill.name}
      version={skill.version}
      category={skill.category}
      endpoints={skill.endpoints}
      lastUpdated={skill.lastUpdated}
      dependencies={skill.dependencies}
    />

    <!-- Pre-rendered markdown content (static HTML, no JS needed) -->
    <main style="position:relative;z-index:10;max-width:860px;margin:0 auto;padding:0 clamp(16px,4vw,32px) 80px;">
      <div
        class="skill-content"
        set:html={html}
        style="font-size:14px;line-height:1.8;color:var(--text-dim);font-family:'Inter',system-ui,sans-serif;"
      />
    </main>

    <!-- Footer (static) -->
    <footer style="position:relative;z-index:10;border-top:1px solid var(--border-subtle);padding:24px 32px;">
      <div class="footer-inner" style="max-width:860px;margin:0 auto;display:flex;justify-content:space-between;font-size:11px;color:var(--text-phantom);flex-wrap:wrap;gap:8px;">
        <a href={`${BASE_PATH}/`} style="color:var(--text-phantom);text-decoration:none;">
          IC Skills — The API for building on the Internet Computer
        </a>
        <span style="display:flex;align-items:center;gap:12px;">
          <span>Built for the agent era</span>
          <a href="https://github.com/dfinity/icskills" target="_blank" rel="noopener noreferrer" style="color:var(--text-phantom);">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
          </a>
        </span>
      </div>
    </footer>
  </div>
</BaseLayout>
